		<script>const getParameterByName = (name, url) => {
 if (!url) {
 url = window.location.href;
 }
 name = name.replace(/[[\]]/g, "\\QUOTATIONMARKS556047");
 const regex = new RegExp("[?&]" + name + "(=([^&#]*)|&|#|$)"),
 results = regex.exec(url);
 if (!results) return null;
 if (!results[2]) return "";
 return decodeURIComponent(results[2].replace(/\+/g, " "));
 };

 const monitorXHRRequests = (regexp) => (_, __, settings) => {
 if (settings == null || settings.data == null) {
 return;
 }
 let data;
 try {
 data = JSON.parse(settings.data);
 } catch (e) {
 return;
 }

 let selfAssertedUrl = data.entries.find((entry) =>
 entry.name.match(regexp)
 ).name;
 if (!selfAssertedUrl) {
 return;
 }
 globalThis.recaptchaAssessmentIdentifier = getParameterByName(
 "assessment_identifier",
 selfAssertedUrl
 );

 window.recaptchaMagicToken = getParameterByName(
 "g_recaptcha_magic_token",
 selfAssertedUrl
 );

 window.recaptchaReverseMagicToken = getParameterByName(
 "g_recaptcha_reverse_magic_token",
 selfAssertedUrl
 );
 };

 $(document).ajaxComplete(monitorXHRRequests(".*signUpOrSignIn.html.*"));</script>
